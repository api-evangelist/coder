{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coder.com/schemas/codersdk-organization.json",
  "title": "Organization",
  "$defs": {},
  "type": "object",
  "required": [
    "created_at",
    "id",
    "is_default",
    "updated_at"
  ],
  "properties": {
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "default_org_member_roles": {
      "type": "array",
      "description": "DefaultOrgMemberRoles are unioned into every member's effective\nroles at request time. Changes propagate to all members on the\nnext request.",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "icon": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "is_default": {
      "type": "boolean"
    },
    "name": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}